{
  "version": 2,
  "functions": {
    "pages/api/**": {
      "maxDuration": 60
    },
    "pages/api/update.ts": {
      "maxDuration": 60
    },
    "pages/api/admin/update.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/update",
      "schedule": "0 7 * * *"
    }
  ],
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs"
}
