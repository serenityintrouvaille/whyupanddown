{
  "name": "whyupanddown",
  "version": 2,
  "env": {
    "GOOGLE_NEWS_API_KEY": "@google_news_api_key",
    "ANTHROPIC_API_KEY": "@anthropic_api_key"
  },
  "functions": {
    "pages/api/**": {
      "maxDuration": 60
    },
    "pages/api/update.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/update",
      "schedule": "0 7 * * *"
    }
  ],
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs"
}
